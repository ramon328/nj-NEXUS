<?xml version="1.0" encoding="UTF-8"?>
<!-- Daemon OPCIONAL: chat web de Claude Code (front para el teléfono).
     Da acceso total al Mac vía PIN + tailnet — instálalo TÚ a conciencia:
       cp ~/nexus/claude-web/com.nexus.claude-chat.plist ~/Library/LaunchAgents/
       launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.nexus.claude-chat.plist
     Quitarlo:
       launchctl bootout gui/$(id -u)/com.nexus.claude-chat
       rm ~/Library/LaunchAgents/com.nexus.claude-chat.plist -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.nexus.claude-chat</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/AIagenteia/nexus/claude-web/start-chat.sh</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/AIagenteia/nexus/claude-web</string>
    <key>EnvironmentVariables</key><dict>
        <key>PATH</key><string>/usr/local/bin:/usr/bin:/bin:/Users/AIagenteia/.local/bin</string>
        <key>HOME</key><string>/Users/AIagenteia</string>
        <key>CLAUDE_CHAT_PORT</key><string>7683</string>
    </dict>
    <key>RunAtLoad</key><true/>
    <key>KeepAlive</key><true/>
    <key>StandardOutPath</key><string>/tmp/claude-chat.log</string>
    <key>StandardErrorPath</key><string>/tmp/claude-chat.log</string>
</dict>
</plist>
